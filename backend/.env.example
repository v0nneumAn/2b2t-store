# Copy to .env and fill in real values. Never commit .env.

# Database (PostgreSQL). For local SQLite dev use: sqlite:///./store.db
DATABASE_URL=postgresql+psycopg2://store:REPLACE_ME@localhost:5432/store
REDIS_URL=redis://localhost:6379/0

# Stripe (required for payment processing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd

# Business rules
MIN_ORDER_USD=10.0
CART_TTL_SECONDS=86400

# API keys — generate strong random values (e.g. openssl rand -hex 32)
BOT_API_KEY=REPLACE_ME
ADMIN_API_KEY=REPLACE_ME

# Frontend URL used for Stripe redirect URLs
FRONTEND_URL=http://localhost:5173

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to true only in local development
DEBUG=false
