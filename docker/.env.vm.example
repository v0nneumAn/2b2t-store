# Copy to .env.vm and fill in real values before running on the VM.
# Then run:
#   docker compose -f docker-compose.yml -f docker-compose.vm.yml --env-file .env.vm up -d
#
# NOTE: This file is an example. Do not put real secrets here and do not commit
# .env.vm to git. Generate strong values with:
#   openssl rand -hex 32

# Database
POSTGRES_PASSWORD=<REPLACE_ME>

# Stripe (test keys are fine for the demo VM)
STRIPE_SECRET_KEY=sk_test_<REPLACE_ME>
STRIPE_PUBLISHABLE_KEY=pk_test_<REPLACE_ME>
STRIPE_WEBHOOK_SECRET=whsec_<REPLACE_ME>
STRIPE_CURRENCY=usd

# Business rules
MIN_ORDER_USD=10.0
CART_TTL_SECONDS=86400

# API keys — generate with: openssl rand -hex 32
BOT_API_KEY=<REPLACE_ME>
ADMIN_API_KEY=<REPLACE_ME>

# JWT secret for admin session cookies — generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=<REPLACE_ME>

# Discord bot
DISCORD_TOKEN=<REPLACE_ME>
GUILD_ID=<REPLACE_ME>

# Public-facing domain for the shop. The web frontend needs this for Stripe redirects.
FRONTEND_URL=https://<your-domain>

# Allowed browser origins. Include the public domain and any local dev origins.
CORS_ORIGINS=https://<your-domain>,http://localhost:5173

# Cloudflare Tunnel token from Zero Trust dashboard → Networks → Tunnels.
TUNNEL_TOKEN=<REPLACE_ME>

# Demo features (disable in production)
DEMO_MODE=true

# Frontend URL used for Stripe redirect URLs
# (same as FRONTEND_URL; kept for compatibility with some scripts)
# FRONTEND_URL=https://<your-domain>

# Optional default ZenithProxy Web API for bot demos.
# Set in ZenithProxy with: webApi auth <token>
# Per-bot config in the database overrides these.
# ZENITH_WEB_API_URL=http://localhost:8080
# ZENITH_WEB_API_TOKEN=<REPLACE_ME>

# Delivery bot (ZenithProxy + DeliveryPlugin)
# Account type: device_code_without_device_token for real Microsoft account,
# offline for local Paper testing.
DELIVERY_BOT_ACCOUNT_TYPE=offline
DELIVERY_BOT_USERNAME=<REPLACE_ME>
DELIVERY_BOT_AUTO_CONNECT=true
DELIVERY_BOT_BIND_PORT=25566
# Minecraft server connection
# For Paper test server: MINECRAFT_SERVER=paper
# For 2b2t:              MINECRAFT_SERVER=connect.2b2t.org
MINECRAFT_SERVER=paper
MINECRAFT_PORT=25565
