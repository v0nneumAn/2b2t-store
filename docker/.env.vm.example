# Copy to .env.vm and fill in real values before running on the VM.
# Then run:
#   docker compose -f docker-compose.yml -f docker-compose.vm.yml --env-file .env.vm up -d

# Database
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD

# Stripe (test keys are fine for the demo VM)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd

# API keys — generate with: openssl rand -hex 32
BOT_API_KEY=REPLACE_ME
ADMIN_API_KEY=REPLACE_ME

# Discord bot
DISCORD_TOKEN=your-bot-token-here
GUILD_ID=your-discord-server-id

# Public-facing domain for the shop. During testing you can point this to the
# VM's LAN IP via Pi-hole/local DNS. The web frontend needs this for Stripe redirects.
FRONTEND_URL=http://shulker.shop

# Allowed browser origins. Include the public domain, Tailscale hostname, and local dev.
CORS_ORIGINS=http://shulker.shop,http://shulker.shop:5173,http://localhost:5173

# Optional ZenithProxy Web API for real bot control
# ZENITH_WEB_API_URL=http://localhost:8080
# ZENITH_WEB_API_TOKEN=REPLACE_ME

# Delivery bot (ZenithProxy + DeliveryPlugin)
# Account type: msa for real Microsoft account, offline for local Paper testing
DELIVERY_BOT_ACCOUNT_TYPE=device_code
DELIVERY_BOT_USERNAME=jaspertalbothale@gmail.com
DELIVERY_BOT_AUTO_CONNECT=true
DELIVERY_BOT_BIND_PORT=25566
# 2b2t connection
MINECRAFT_SERVER=connect.2b2t.org
MINECRAFT_PORT=25565
